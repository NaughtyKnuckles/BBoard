PORT=3000
NODE_ENV=development

# URL where the frontend is served (Vercel production URL in prod)
FRONTEND_URL=http://localhost:3001

# Comma-separated allowed browser origins for API requests.
# Example: https://app.example.com,https://staging-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3001

# Required in production. In local dev the app falls back to a temporary default.
SESSION_SECRET=replace_with_a_long_random_string

# Optional for local development. Required only if you use Strava integration.
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
# Optional override. If omitted, backend auto-uses:
#   https://<current-backend-host>/auth/strava/callback
# STRAVA_REDIRECT_URI=http://localhost:3000/auth/strava/callback
