{
  "name": "novaboard-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"node frontend/dev-server.js\"",
    "dev:frontend": "node frontend/dev-server.js",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build -w frontend && npm run build -w backend",
    "start": "npm run start -w backend",
    "check:rejects": "bash scripts/check-rejects.sh",
    "clean:rejects": "bash scripts/clean-rejects.sh"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
