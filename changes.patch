+:root {
+  --bg: #f6f4f1;
+  --bg-radial: radial-gradient(circle at 15% 15%, #fff7ed 0%, #f6f4f1 45%);
+  --card: rgba(255, 255, 255, 0.78);
+  --surface: #ffffff;
+  --line: #eadfd6;
+  --text: #23160f;
+  --muted: #876f63;
+  --accent: #f08a4b;
+  --accent-2: #ffb07a;
+  --success: #4ea36c;
+  --danger: #d65757;
+  --shadow: 0 14px 44px rgba(139, 82, 44, 0.14);
+  --radius-lg: 22px;
+  --radius-md: 16px;
+}
+
+body.dark {
+  --bg: #131416;
+  --bg-radial: radial-gradient(circle at 15% 15%, #2a211b 0%, #131416 48%);
+  --card: rgba(29, 32, 35, 0.82);
+  --surface: #1f2328;
+  --line: #32363c;
+  --text: #eef1f5;
+  --muted: #aeb7c3;
+  --accent: #ff9a56;
+  --accent-2: #ffc195;
+  --shadow: 0 14px 44px rgba(0, 0, 0, 0.35);
+}
+
+* { box-sizing: border-box; }
+body {
+  margin: 0;
+  font-family: Inter, -apple-system, BlinkMacSystemFont, sans-serif;
+  background: var(--bg-radial);
+  color: var(--text);
+  min-height: 100vh;
+  transition: background 0.3s ease, color 0.3s ease;
+}
+
+.app-shell { display: grid; grid-template-columns: 260px 1fr; min-height: 100vh; }
+.glass {
+  background: var(--card);
+  backdrop-filter: blur(14px);
+  border: 1px solid rgba(255,255,255,0.45);
+  box-shadow: var(--shadow);
+}
+.sidebar {
+  margin: 18px;
+  padding: 18px;
+  border-radius: var(--radius-lg);
+  display: flex;
+  flex-direction: column;
+  gap: 16px;
+}
+.brand { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
+.brand-mark {
+  width: 42px; height: 42px; border-radius: 12px;
+  display: grid; place-items: center;
+  background: linear-gradient(145deg, var(--accent), var(--accent-2));
+  color: white; font-weight: 800;
+}
+.brand h1 { margin: 0; font-size: 1rem; }
+.brand p { margin: 2px 0 0; font-size: 0.75rem; color: var(--muted); }
+.nav { display: flex; flex-direction: column; gap: 6px; }
+.nav-item {
+  background: transparent;
+  border: 1px solid transparent;
+  color: var(--text);
+  padding: 11px 12px;
+  border-radius: 12px;
+  text-align: left;
+  font-weight: 600;
+  cursor: pointer;
+  display: flex;
+  gap: 10px;
+  transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease;
+}
+.nav-item:hover { transform: translateX(4px); border-color: var(--line); background: rgba(255,255,255,0.38); }
+.nav-item.active { background: linear-gradient(140deg, rgba(240,138,75,0.22), rgba(255,176,122,0.22)); border-color: rgba(240,138,75,0.38); }
+.sidebar-footer { margin-top: auto; }
+
+.content { padding: 20px 22px 28px 0; }
+.topbar {
+  border-radius: var(--radius-lg);
+  padding: 18px 20px;
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+  gap: 16px;
+}
+.topbar h2 { margin: 0; font-size: clamp(1.25rem, 2vw, 1.8rem); }
+.topbar p { margin: 4px 0 0; color: var(--muted); }
+.topbar-actions { display: flex; align-items: center; gap: 8px; }
+
+input, select, button {
+  font: inherit;
+}
+input, select {
+  background: var(--surface);
+  color: var(--text);
+  border: 1px solid var(--line);
+  border-radius: 12px;
+  padding: 10px 12px;
+  min-height: 42px;
+}
+input:focus, select:focus {
+  outline: none;
+  border-color: var(--accent);
+  box-shadow: 0 0 0 4px rgba(240,138,75,0.18);
+}
+.btn, .ghost-btn {
+  border: none;
+  border-radius: 12px;
+  padding: 10px 14px;
+  font-weight: 600;
+  cursor: pointer;
+  transition: transform 0.25s ease, filter 0.25s ease, background 0.25s ease;
+}
+.btn {
+  color: white;
+  background: linear-gradient(145deg, var(--accent), var(--accent-2));
+}
+.btn.secondary { background: linear-gradient(145deg, #8e9ab8, #aab8d4); }
+.btn:hover, .ghost-btn:hover { transform: translateY(-1px); filter: brightness(1.05); }
+.ghost-btn { width: 100%; background: rgba(255,255,255,0.4); color: var(--text); border: 1px solid var(--line); }
+
+.page { display: none; margin-top: 20px; }
+.page.active { display: block; animation: fadeIn 0.3s ease; }
+@keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
+
+.grid { display: grid; gap: 14px; }
+.cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
+.cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
+.mt-10 { margin-top: 10px; }
+.mt-14 { margin-top: 14px; }
+.mt-16 { margin-top: 16px; }
+.mt-20 { margin-top: 20px; }
+
+.card {
+  border-radius: var(--radius-lg);
+  padding: 18px;
+  border: 1px solid rgba(255,255,255,0.32);
+}
+.card:hover { transform: translateY(-2px); transition: transform 0.25s ease; }
+.section-head h3 { margin: 0; font-size: 1.05rem; }
+.section-head p { margin: 6px 0 0; color: var(--muted); font-size: 0.92rem; }
+
+.form-inline {
+  margin-top: 14px;
+  display: grid;
+  grid-template-columns: 1.5fr 1fr auto;
+  gap: 8px;
+}
+.form-grid {
+  display: grid;
+  grid-template-columns: repeat(3, minmax(0, 1fr));
+  gap: 8px;
+}
+
+.stack-list { display: flex; flex-direction: column; gap: 8px; }
+.item-row {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 12px;
+  border: 1px solid var(--line);
+  background: rgba(255,255,255,0.45);
+  border-radius: 14px;
+  padding: 10px 12px;
+  transition: transform 0.2s ease;
+}
+.item-row:hover { transform: translateY(-1px); }
+.item-meta { color: var(--muted); font-size: 0.85rem; }
+.item-actions { display: flex; gap: 6px; align-items: center; }
+.icon-btn {
+  border: 1px solid var(--line);
+  background: var(--surface);
+  color: var(--text);
+  border-radius: 9px;
+  cursor: pointer;
+  padding: 6px 8px;
+}
+.icon-btn.danger { color: var(--danger); }
+.badge {
+  font-size: 0.72rem;
+  border-radius: 999px;
+  padding: 4px 9px;
+  font-weight: 700;
+}
+.badge.high { background: rgba(214,87,87,0.14); color: #b33737; }
+.badge.medium { background: rgba(240,138,75,0.16); color: #a95b28; }
+.badge.low { background: rgba(78,163,108,0.16); color: #2f7d4a; }
+
+.progress-track {
+  height: 10px;
+  border-radius: 999px;
+  background: rgba(0,0,0,0.08);
+  overflow: hidden;
+}
+.progress-fill {
+  width: 0;
+  height: 100%;
+  border-radius: inherit;
+  background: linear-gradient(90deg, var(--accent), var(--accent-2));
+  transition: width 0.35s ease;
+}
+.meter-head {
+  display: flex;
+  justify-content: space-between;
+  gap: 8px;
+  font-size: 0.92rem;
+  margin-bottom: 8px;
+}
+.tiny-meta { margin-top: 10px; color: var(--muted); font-size: 0.86rem; }
+
+.timeline { margin-top: 14px; display: flex; flex-direction: column; gap: 8px; }
+.timeline-item {
+  border-left: 3px solid var(--accent);
+  border-radius: 0 12px 12px 0;
+  padding: 10px 12px;
+  background: rgba(255,255,255,0.45);
+  border: 1px solid var(--line);
+}
+.timeline-top { display: flex; justify-content: space-between; align-items: center; gap: 8px; }
+
+.habit-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
+.habit-btn {
+  border: 1px solid var(--line);
+  background: rgba(255,255,255,0.45);
+  color: var(--text);
+  border-radius: 12px;
+  padding: 10px;
+  font-weight: 600;
+  cursor: pointer;
+  transition: all 0.25s ease;
+}
+.habit-btn.active { border-color: var(--accent); background: rgba(240,138,75,0.16); }
+
+.bar-chart { margin-top: 12px; display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; align-items: end; height: 220px; }
+.bar-col { text-align: center; }
+.bar {
+  width: 100%;
+  border-radius: 10px 10px 6px 6px;
+  background: linear-gradient(180deg, var(--accent-2), var(--accent));
+  min-height: 8px;
+  transition: height 0.35s ease;
+}
+.bar-label { margin-top: 6px; font-size: 0.75rem; color: var(--muted); }
+.bar-value { font-size: 0.72rem; color: var(--muted); }
+
+.toast-container {
+  position: fixed;
+  top: 16px;
+  right: 16px;
+  display: flex;
+  flex-direction: column;
+  gap: 8px;
+  z-index: 999;
+}
+.toast {
+  min-width: 220px;
+  background: var(--surface);
+  border: 1px solid var(--line);
+  color: var(--text);
+  border-radius: 12px;
+  padding: 10px 12px;
+  box-shadow: var(--shadow);
+  animation: toastIn 0.25s ease;
+}
+@keyframes toastIn { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
+
+.empty { color: var(--muted); padding: 14px 0; text-align: center; }
+
+@media (max-width: 1080px) {
+  .app-shell { grid-template-columns: 84px 1fr; }
+  .sidebar .brand div, .nav-item span, .ghost-btn { display: none; }
+  .nav-item { justify-content: center; }
+  .sidebar { align-items: center; padding: 14px 10px; }
+  .content { padding-left: 0; }
+}
+
+@media (max-width: 840px) {
+  .cols-3, .cols-2, .form-inline, .form-grid, .habit-grid { grid-template-columns: 1fr; }
+  .topbar { flex-direction: column; align-items: stretch; }
+  .topbar-actions { width: 100%; }
+  .content { padding: 14px; }
+  .sidebar { margin: 12px; }
+  .app-shell { grid-template-columns: 1fr; }
+  .sidebar { position: sticky; top: 10px; z-index: 5; }
+}
