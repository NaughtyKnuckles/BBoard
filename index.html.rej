-<script>
-// ---- STATE ----
-let state = {
-  todos: [],
-  goals: [],
-  wants: [],
-  schedule: [],
-  customSections: [],
-  fitness: {
-    workouts: [], // {id, date, type, note, timestamp}
-    walks: []     // {id, date, km, min, note, timestamp}
-  }
-};
-
-let selectedFitType = null;
-
-// ---- STORAGE ----
-async function saveState() {
-  try { await window.storage.set('dashboard_state_v2', JSON.stringify(state)); } catch(e) {}
-}
-async function loadState() {
-  try {
-    const r = await window.storage.get('dashboard_state_v2');
-    if (r) {
-      const loaded = JSON.parse(r.value);
-      state = { ...state, ...loaded };
-      if (!state.fitness) state.fitness = { workouts: [], walks: [] };
-      if (!state.fitness.workouts) state.fitness.workouts = [];
-      if (!state.fitness.walks) state.fitness.walks = [];
-    }
-  } catch(e) {}
-}
+      </section>
 
-// ---- NAVIGATION ----
-function showPage(id) {
-  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
-  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
-  const page = document.getElementById('page-' + id);
-  if (page) page.classList.add('active');
-  const nav = document.getElementById('nav-' + id);
-  if (nav) nav.classList.add('active');
-  renderAll();
-}
-
-// ---- DATE UTILS ----
-function todayStr() {
-  const d = new Date();
-  return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
-}
-function dateStr(ts) {
-  const d = new Date(ts);
-  return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
-}
-function friendlyDate(ts) {
-  const d = new Date(ts);
-  const t = todayStr();
-  const s = dateStr(ts);
-  if (s === t) return 'Today';
-  const yesterday = new Date(); yesterday.setDate(yesterday.getDate()-1);
-  const yStr = yesterday.getFullYear() + '-' + String(yesterday.getMonth()+1).padStart(2,'0') + '-' + String(yesterday.getDate()).padStart(2,'0');
-  if (s === yStr) return 'Yesterday';
-  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
-  return `${months[d.getMonth()]} ${d.getDate()}`;
-}
-function setDate() {
-  const now = new Date();
-  const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
-  const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
-  document.getElementById('home-date-text').textContent =
-    `${days[now.getDay()]}, ${months[now.getMonth()]} ${now.getDate()}, ${now.getFullYear()}`;
-}
-
-// ---- TODO ----
-function addTodo() {
-  const input = document.getElementById('todo-input');
-  const tag = document.getElementById('todo-tag').value;
-  if (!input.value.trim()) return;
-  state.todos.push({ id: Date.now(), text: input.value.trim(), tag, done: false });
-  input.value = ''; saveState(); renderTodos(); updateHomeCounts();
-}
-function toggleTodo(id) {
-  const t = state.todos.find(x => x.id === id);
-  if (t) { t.done = !t.done; saveState(); renderTodos(); }
-}
-function deleteTodo(id) {
-  state.todos = state.todos.filter(x => x.id !== id);
-  saveState(); renderTodos(); updateHomeCounts();
-}
-function renderTodos() {
-  const el = document.getElementById('todo-list');
-  if (!el) return;
-  if (!state.todos.length) { el.innerHTML = `<div class="empty-state"><div class="empty-icon">📋</div><p>No tasks yet — add one above!</p></div>`; return; }
-  el.innerHTML = state.todos.map(t => `
-    <div class="todo-item">
-      <div class="todo-check ${t.done ? 'done' : ''}" onclick="toggleTodo(${t.id})"></div>
-      <span class="todo-text ${t.done ? 'done' : ''}">${esc(t.text)}</span>
-      ${t.tag ? `<span class="todo-tag ${t.tag}">${t.tag}</span>` : ''}
-      <button class="btn-danger" onclick="deleteTodo(${t.id})">×</button>
-    </div>`).join('');
-}
-
-// ---- GOALS ----
-function addGoal() {
-  const input = document.getElementById('goal-input');
-  const cat = document.getElementById('goal-cat').value.trim();
-  if (!input.value.trim()) return;
-  state.goals.push({ id: Date.now(), name: input.value.trim(), cat, progress: 0 });
-  input.value = ''; document.getElementById('goal-cat').value = '';
-  saveState(); renderGoals(); updateHomeCounts();
-}
-function changeProgress(id, delta) {
-  const g = state.goals.find(x => x.id === id);
-  if (g) { g.progress = Math.max(0, Math.min(100, g.progress + delta)); saveState(); renderGoals(); }
-}
-function deleteGoal(id) {
-  state.goals = state.goals.filter(x => x.id !== id);
-  saveState(); renderGoals(); updateHomeCounts();
-}
-function renderGoals() {
-  const el = document.getElementById('goals-list');
-  if (!el) return;
-  if (!state.goals.length) { el.innerHTML = `<div class="empty-state"><div class="empty-icon">🎯</div><p>No goals yet — set one above!</p></div>`; return; }
-  el.innerHTML = state.goals.map(g => `
-    <div class="goal-item">
-      <div class="goal-top">
-        <div><div class="goal-name">${esc(g.name)}</div>${g.cat ? `<div class="goal-cat">${esc(g.cat)}</div>` : ''}</div>
-        <button class="btn-danger" onclick="deleteGoal(${g.id})">×</button>
-      </div>
-      <div class="progress-wrap">
-        <div class="progress-bar"><div class="progress-fill" style="width:${g.progress}%"></div></div>
-        <span class="progress-pct">${g.progress}%</span>
-        <div class="progress-controls">
-          <button class="prog-btn" onclick="changeProgress(${g.id}, -10)">−</button>
-          <button class="prog-btn" onclick="changeProgress(${g.id}, 10)">+</button>
+      <section class="page" id="page-todo">
+        <div class="card glass">
+          <div class="section-head">
+            <h3>Smart Productivity</h3>
+            <p>Priority-based tasks with completion tracking.</p>
+          </div>
+          <form class="form-inline" id="todo-form">
+            <input id="todo-input" type="text" placeholder="Add a high-impact task..." required />
+            <select id="todo-priority">
+              <option value="high">High Priority</option>
+              <option value="medium" selected>Medium Priority</option>
+              <option value="low">Low Priority</option>
+            </select>
+            <button class="btn" type="submit">Add Task</button>
+          </form>
+          <div id="todo-progress" class="tiny-meta"></div>
+          <div id="todo-list" class="stack-list"></div>
         </div>
-      </div>
-    </div>`).join('');
-}
-
-// ---- WANTS ----
-const wantEmojis = { high:'💫', medium:'✨', low:'🌱' };
-function addWant() {
-  const input = document.getElementById('want-input');
-  const note = document.getElementById('want-note').value.trim();
-  const priority = document.getElementById('want-priority').value;
-  if (!input.value.trim()) return;
-  state.wants.push({ id: Date.now(), name: input.value.trim(), note, priority });
-  input.value = ''; document.getElementById('want-note').value = '';
-  saveState(); renderWants(); updateHomeCounts();
-}
-function deleteWant(id) {
-  state.wants = state.wants.filter(x => x.id !== id);
-  saveState(); renderWants(); updateHomeCounts();
-}
-function renderWants() {
-  const el = document.getElementById('wants-list');
-  if (!el) return;
-  if (!state.wants.length) { el.innerHTML = `<div class="empty-state"><div class="empty-icon">✨</div><p>Nothing here yet — add your wishes!</p></div>`; return; }
-  el.innerHTML = state.wants.map(w => `
-    <div class="want-item">
-      <span class="want-emoji">${wantEmojis[w.priority] || '✨'}</span>
-      <div class="want-info">
-        <div class="want-name">${esc(w.name)}</div>
-        ${w.note ? `<div class="want-meta">${esc(w.note)}</div>` : ''}
-      </div>
-      <div class="priority-dot ${w.priority}"></div>
-      <button class="btn-danger" onclick="deleteWant(${w.id})">×</button>
-    </div>`).join('');
-}
-
-// ---- SCHEDULE ----
-function addSchedule() {
-  const time = document.getElementById('sched-time').value;
-  const title = document.getElementById('sched-title').value.trim();
-  const type = document.getElementById('sched-type').value;
-  if (!title) return;
-  state.schedule.push({ id: Date.now(), time, title, type });
-  state.schedule.sort((a,b) => a.time.localeCompare(b.time));
-  document.getElementById('sched-title').value = '';
-  saveState(); renderSchedule(); updateHomeCounts();
-}
-function deleteSchedule(id) {
-  state.schedule = state.schedule.filter(x => x.id !== id);
-  saveState(); renderSchedule(); updateHomeCounts();
-}
-function fmt12(t) {
-  if (!t) return '—';
-  let [h,m] = t.split(':'); h = parseInt(h);
-  const ampm = h >= 12 ? 'PM' : 'AM';
-  h = h % 12 || 12;
-  return `${h}:${m} ${ampm}`;
-}
-function renderSchedule() {
-  const el = document.getElementById('schedule-list');
-  if (!el) return;
-  if (!state.schedule.length) { el.innerHTML = `<div class="empty-state"><div class="empty-icon">🗓️</div><p>No events yet — plan your day!</p></div>`; return; }
-  el.innerHTML = state.schedule.map(s => `
-    <div class="schedule-slot">
-      <div class="slot-time">${fmt12(s.time)}</div>
-      <div class="slot-content">
-        <div class="slot-title">${esc(s.title)}</div>
-        <span class="slot-type ${s.type}">${s.type}</span>
-      </div>
-      <button class="btn-danger" onclick="deleteSchedule(${s.id})">×</button>
-    </div>`).join('');
-}
-
-// ---- FITNESS ----
-const fitInfo = {
-  push: { icon: '💪', label: 'Push', cls: 'push' },
-  pull: { icon: '🏋️', label: 'Pull', cls: 'pull' },
-  legs: { icon: '🦵', label: 'Legs', cls: 'legs' },
-  walk: { icon: '🚶', label: 'Walk', cls: 'walk' },
-  rest: { icon: '😴', label: 'Rest', cls: 'rest' }
-};
-
-function selectFitType(type) {
-  selectedFitType = type;
-  document.querySelectorAll('.fit-type-btn').forEach(b => {
-    b.className = 'fit-type-btn';
-  });
-  const btn = document.getElementById('ftbtn-' + type);
-  if (btn) btn.className = 'fit-type-btn selected-' + type;
-}
-
-function logWorkout() {
-  if (!selectedFitType) { alert('Please choose a workout type first!'); return; }
-  const note = document.getElementById('fit-note').value.trim();
-  state.fitness.workouts.unshift({
-    id: Date.now(),
-    date: todayStr(),
-    type: selectedFitType,
-    note,
-    timestamp: Date.now()
-  });
-  document.getElementById('fit-note').value = '';
-  selectedFitType = null;
-  document.querySelectorAll('.fit-type-btn').forEach(b => b.className = 'fit-type-btn');
-  saveState();
-  renderFitness();
-  updateHomeCounts();
-}
+      </section>
 
-function logWalk() {
-  const km = parseFloat(document.getElementById('walk-km').value);
-  const min = parseFloat(document.getElementById('walk-min').value);
-  const note = document.getElementById('walk-note').value.trim();
-  if (!km || km <= 0) { alert('Please enter a distance!'); return; }
-  state.fitness.walks.unshift({
-    id: Date.now(),
-    date: todayStr(),
-    km: Math.round(km * 10) / 10,
-    min: min || null,
-    note,
-    timestamp: Date.now()
-  });
-  document.getElementById('walk-km').value = '';
-  document.getElementById('walk-min').value = '';
-  document.getElementById('walk-note').value = '';
-  saveState();
-  renderFitness();
-  updateHomeCounts();
-}
-
-function deleteWorkout(id) {
-  state.fitness.workouts = state.fitness.workouts.filter(x => x.id !== id);
-  saveState(); renderFitness(); updateHomeCounts();
-}
-function deleteWalkLog(id) {
-  state.fitness.walks = state.fitness.walks.filter(x => x.id !== id);
-  saveState(); renderFitness(); updateHomeCounts();
-}
