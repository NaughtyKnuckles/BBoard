-// ---- CUSTOM SECTIONS ----
-function openNewSectionModal() {
-  document.getElementById('new-section-name').value = '';
-  document.getElementById('new-section-icon').value = '';
-  document.getElementById('modal-new-section').style.display = 'flex';
-  setTimeout(() => document.getElementById('new-section-name').focus(), 50);
-}
-function closeModal(id) { document.getElementById(id).style.display = 'none'; }
-function createNewSection() {
-  const name = document.getElementById('new-section-name').value.trim();
-  const icon = document.getElementById('new-section-icon').value.trim() || '📌';
-  if (!name) return;
-  const id = 'custom_' + Date.now();
-  state.customSections.push({ id, name, icon, items: [] });
-  saveState(); renderCustomNav(); renderCustomPages();
-  closeModal('modal-new-section');
-  showPage(id);
-}
-function addCustomItem(secId) {
-  const input = document.getElementById('ci-' + secId);
-  if (!input || !input.value.trim()) return;
-  const sec = state.customSections.find(s => s.id === secId);
-  if (sec) { sec.items.push({ id: Date.now(), text: input.value.trim() }); input.value = ''; saveState(); renderCustomSection(secId); updateHomeCounts(); }
-}
-function deleteCustomItem(secId, itemId) {
-  const sec = state.customSections.find(s => s.id === secId);
-  if (sec) { sec.items = sec.items.filter(i => i.id !== itemId); saveState(); renderCustomSection(secId); updateHomeCounts(); }
-}
-function deleteCustomSection(secId) {
-  state.customSections = state.customSections.filter(s => s.id !== secId);
-  saveState(); renderCustomNav(); renderCustomPages(); showPage('home');
-}
-function renderCustomSection(secId) {
-  const el = document.getElementById('clist-' + secId);
-  if (!el) return;
-  const sec = state.customSections.find(s => s.id === secId);
-  if (!sec || !sec.items.length) { el.innerHTML = `<div class="empty-state"><div class="empty-icon">${sec ? sec.icon : '📌'}</div><p>Nothing here yet!</p></div>`; return; }
-  el.innerHTML = sec.items.map(item => `
-    <div class="todo-item">
-      <span class="todo-text">${esc(item.text)}</span>
-      <button class="btn-danger" onclick="deleteCustomItem('${secId}',${item.id})">×</button>
-    </div>`).join('');
-}
-function renderCustomNav() {
-  const el = document.getElementById('custom-nav-items');
-  el.innerHTML = state.customSections.map(s => `
-    <div class="nav-item" onclick="showPage('${s.id}')" id="nav-${s.id}">
-      <span class="icon">${s.icon}</span><span>${esc(s.name)}</span>
-    </div>`).join('');
-}
-function renderCustomPages() {
-  const container = document.getElementById('custom-pages');
-  container.innerHTML = state.customSections.map(s => `
-    <div class="page" id="page-${s.id}">
-      <div class="page-header" style="display:flex;align-items:flex-end;justify-content:space-between">
-        <div><h1>${s.icon} <em>${esc(s.name)}</em></h1><p>Your custom section</p></div>
-        <button class="btn btn-sm btn-ghost" onclick="deleteCustomSection('${s.id}')" style="margin-bottom:4px">Delete section</button>
-      </div>
-      <div class="card">
-        <div class="input-row">
-          <input type="text" id="ci-${s.id}" placeholder="Add an item..." onkeydown="if(event.key==='Enter')addCustomItem('${s.id}')"/>
-          <button class="btn" onclick="addCustomItem('${s.id}')">Add</button>
+          <div id="strava-activities-list" class="stack-list mt-14"></div>
         </div>
-        <div id="clist-${s.id}"></div>
-      </div>
-    </div>`).join('');
-  state.customSections.forEach(s => renderCustomSection(s.id));
-}
