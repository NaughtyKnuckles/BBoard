-// ---- HOME COUNTS ----
-function updateHomeCounts() {
-  const tc = document.getElementById('hc-todo');
-  const gc = document.getElementById('hc-goals');
-  const wc = document.getElementById('hc-wants');
-  const sc = document.getElementById('hc-schedule');
-  const fc = document.getElementById('hc-fitness');
-  if (tc) tc.textContent = state.todos.filter(t => !t.done).length + ' left';
-  if (gc) gc.textContent = state.goals.length + ' goals';
-  if (wc) wc.textContent = state.wants.length + ' items';
-  if (sc) sc.textContent = state.schedule.length + ' events';
-  if (fc) {
-    const streak = getStreak();
-    const totalW = state.fitness.workouts.filter(w => w.type !== 'rest').length;
-    fc.textContent = streak > 0 ? '🔥 ' + streak + ' day streak' : totalW + ' workouts';
-  }
-}
-
-// ---- RENDER ALL ----
-function renderAll() {
-  renderTodos(); renderGoals(); renderWants(); renderSchedule();
-  renderFitness();
-  state.customSections.forEach(s => renderCustomSection(s.id));
-  updateHomeCounts();
-}
