-function clearFitnessConfirm() {
-  if (confirm('Clear all fitness history? This cannot be undone.')) {
-    state.fitness.workouts = [];
-    state.fitness.walks = [];
-    saveState(); renderFitness(); updateHomeCounts();
-  }
-}
-
-function calcPace(km, min) {
-  if (!km || !min || min <= 0) return null;
-  const paceMin = min / km;
-  const paceM = Math.floor(paceMin);
-  const paceS = Math.round((paceMin - paceM) * 60);
-  return `${paceM}:${String(paceS).padStart(2,'0')} min/km`;
-}
-
-function getStreak() {
-  if (!state.fitness.workouts.length && !state.fitness.walks.length) return 0;
-  // Collect all unique activity dates
-  const activeDates = new Set([
-    ...state.fitness.workouts.map(w => w.date),
-    ...state.fitness.walks.map(w => w.date)
-  ]);
-  let streak = 0;
-  const d = new Date();
-  // Check if today is active; if not, start from yesterday
-  const t = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
-  if (!activeDates.has(t)) d.setDate(d.getDate() - 1);
-  while (true) {
-    const key = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
-    if (!activeDates.has(key)) break;
-    streak++;
-    d.setDate(d.getDate() - 1);
-  }
-  return streak;
-}
